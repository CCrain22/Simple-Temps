#:kivy 2.0.0

<TempRead>:
    cputemp: temp_left
    cpupercent: per_left
    gputemp: temp_right
    gpupercent: per_right

    canvas.before:
        Color:
            rgba: 1, 1, 1, 0.1
        Rectangle:
            pos: self.pos
            size: self.size
    canvas:
        #dividing line
        Rectangle:
            pos: self.center_x - 5, 0
            size: 10, self.height
    
    #CPU labels
    Label:
        font_size: 50
        center_x: root.width / 4
        top: root.top - 20
        text: 'CPU'
    #Temp
    Label:
        font_size: 70
        center_x: root.width / 4
        top: root.top - 80
        text: str(root.cputemp.numdef) + '°'
    #Percent
    Label:
        font_size: 70
        center_x: root.width / 4
        top: root.top - 150
        text: str(root.cpupercent.numdef) + '%'
    
    #GPU labels
    Label:
        font_size: 50
        center_x: root.width * 3 / 4
        top: root.top - 20
        text: 'GPU'
    #Temp
    Label:
        font_size: 70
        center_x: root.width * 3 / 4
        top: root.top - 80
        text: str(root.gputemp.numdef) + '°'
    #Percent
    Label:
        font_size: 70
        center_x: root.width * 3 / 4
        top: root.top - 150
        text: str(root.gpupercent.numdef) + '%'
    
    #CPU placement
    #Temp
    NumDef:
        id: temp_left
        x: root.x
        center_y: root.center_y
    #Percent
    NumDef:
        id: per_left
        x: root.x
        center_y: root.center_y

    #GPU placement
    #Temp
    NumDef:
        id: temp_right
        x: root.width - self.width
        center_y: root.center_y
    #percent
    NumDef:
        id: per_right
        x:root.width - self.width
        center_y: root.center_y

